{
  "name": "@vectrade/ai-provider",
  "version": "0.1.0",
  "description": "VecTrade provider for Vercel AI SDK — use financial AI tools in any AI framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vectrade",
    "ai",
    "vercel-ai-sdk",
    "provider",
    "tools",
    "finance"
  ],
  "author": "VecTrade <sdk@vectrade.io>",
  "license": "MIT",
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^2.1.9",
    "ai": "^3.3.0",
    "eslint": "^9.39.4",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  }
}
