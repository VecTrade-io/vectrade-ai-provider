{
  "name": "@vectrade/ai-provider",
  "version": "0.1.0",
  "description": "VecTrade provider for Vercel AI SDK — use financial AI tools in any AI framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VecTrade-io/vectrade-ai-provider.git"
  },
  "homepage": "https://docs.vectrade.io/sdks/ai-provider",
  "bugs": {
    "url": "https://github.com/VecTrade-io/vectrade-ai-provider/issues"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "vectrade",
    "ai",
    "vercel-ai-sdk",
    "provider",
    "tools",
    "finance"
  ],
  "author": "VecTrade <sdk@vectrade.io>",
  "license": "MIT",
  "peerDependencies": {
    "ai": ">=3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "ai": "^3.3.0",
    "eslint": "^10.4.0",
    "tsup": "^8.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "zod": "^3.23.0"
  }
}
